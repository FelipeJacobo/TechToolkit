# AI Dev Assistant V4 — Environment Configuration
# Copy this file to .env and fill in the values

# ── OpenAI (required for agent analysis) ──
OPENAI_API_KEY=sk-proj-your-api-key-here
ANALYSIS_MODEL=gpt-4o
AGENT_MODEL=gpt-4o

# ── JWT ──
JWT_SECRET=generate-a-random-32-character-secret-key

# ── Ports ──
API_PORT=8081
WEB_PORT=3000
AGENT_PORT=8080

# ── Infra (Docker auto-configures these; only change for local dev) ──
# DATABASE_URL=postgresql://ai_dev_app:dev_password_123@localhost:5432/ai_dev
# REDIS_URL=redis://:redis_pass_123@localhost:6379
# NATS_SERVERS=nats://localhost:4222
