{
  "name": "ai-dev-agent-v4",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "vscode-extension"
  ],
  "scripts": {
    "dev:core": "tsx watch src/index.ts",
    "build:core": "tsc -p tsconfig.json",
    "start:core": "node dist/index.js",
    "test:core": "vitest run",
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present && tsc -p tsconfig.json",
    "lint": "npm run lint --workspaces --if-present",
    "install:all": "npm install"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^1.23.0",
    "@opentelemetry/sdk-trace-node": "^1.23.0",
    "fastify": "^4.26.2",
    "ioredis": "^5.4.1",
    "isolated-vm": "^5.0.4",
    "nats": "^2.28.0",
    "pg": "^8.13.1",
    "pino": "^8.19.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
