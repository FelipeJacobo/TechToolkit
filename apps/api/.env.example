# ─────────────────────────────────────────────────────
# Environment variables for the SaaS API
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────
NODE_ENV=development
API_PORT=8081
BASE_URL=http://localhost:8081

# ── JWT — REQUIRED — generate a strong secret ─────────
# openssl rand -hex 32
JWT_SECRET=

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://ai_dev_app:CHANGE_ME@localhost:5432/ai_dev

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# ── NATS ──────────────────────────────────────────────
NATS_SERVERS=nats://localhost:4222

# ── OAuth (optional) ─────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OpenAI / Embeddings ──────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Stripe (optional) ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_METER_EVENT_NAME=
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# ── Rate limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ── Admin ─────────────────────────────────────────────
ADMIN_TOKEN=generate-a-random-token-with-openssl-rand-hex-32

# ── Email notification webhook (optional) ────────────
INVITE_EMAIL_WEBHOOK=

# ── Retention (days) ─────────────────────────────────
RETENTION_DAYS=30
